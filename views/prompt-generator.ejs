<% layout('layout') -%>

<div class="container mx-auto px-3 sm:px-4 py-5 sm:py-8 max-w-[1400px]">
    <!-- Header Section -->
    <div class="flex items-center gap-3 sm:gap-4 mb-5 sm:mb-8">
        <div class="w-10 h-10 sm:w-12 sm:h-12 bg-primary/20 rounded-2xl flex items-center justify-center shadow-lg shadow-primary/10 border border-primary/20">
            <i class="ti ti-sparkles text-primary text-2xl animate-pulse"></i>
        </div>
        <div class="min-w-0">
            <h1 class="text-xl sm:text-2xl font-black text-white tracking-tight">AI Prompt Studio</h1>
            <p class="text-[9px] sm:text-[10px] text-gray-500 uppercase tracking-[0.2em] sm:tracking-[0.3em] font-bold truncate">Creative Generation Suite</p>
        </div>
    </div>

    <!-- Main Studio Container -->
    <div class="bg-dark-800 rounded-2xl sm:rounded-3xl border border-gray-700/30 shadow-2xl overflow-hidden flex flex-col min-h-[600px]">
        <!-- Minimal Tabs (3 Tabs Now) -->
        <div class="p-3 bg-dark-900/60 border-b border-gray-700/30 flex flex-col md:flex-row gap-3 md:justify-between md:items-center">
            <div class="studio-tab-list flex w-full md:w-auto overflow-x-auto bg-dark-700/50 p-1 rounded-xl">
                <button onclick="switchStudioTab('builder')" id="tab-builder" class="studio-tab active flex flex-1 md:flex-none justify-center items-center gap-2 min-w-[8.5rem] px-4 sm:px-10 py-2.5 rounded-lg text-[11px] font-bold transition-all whitespace-nowrap">
                    <i class="ti ti-wand text-xs"></i> Prompt Builder
                </button>
                <button onclick="switchStudioTab('generate')" id="tab-generate" class="studio-tab flex flex-1 md:flex-none justify-center items-center gap-2 min-w-[8.5rem] px-4 sm:px-10 py-2.5 rounded-lg text-[11px] font-bold transition-all text-gray-500 hover:text-gray-300 whitespace-nowrap">
                    <i class="ti ti-photo text-xs"></i> Generate Image
                </button>
                <button onclick="switchStudioTab('history')" id="tab-history" class="studio-tab flex flex-1 md:flex-none justify-center items-center gap-2 min-w-[6.5rem] px-4 sm:px-10 py-2.5 rounded-lg text-[11px] font-bold transition-all text-gray-500 hover:text-gray-300 whitespace-nowrap">
                    <i class="ti ti-history text-xs"></i> History
                </button>
            </div>
            <div class="hidden md:flex items-center gap-2 px-4 py-1.5 bg-primary/10 border border-primary/20 rounded-full">
                <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse"></span>
                <span class="text-[9px] text-primary font-black uppercase tracking-widest">Ready to Create</span>
            </div>
        </div>

        <div class="flex-1 p-4 sm:p-6 overflow-y-auto custom-scrollbar">
            <!-- Tab 1: Prompt Builder -->
            <div id="studio-builder" class="studio-content space-y-8">
                <!-- Magic Section -->
                <div class="bg-primary/5 rounded-2xl p-4 border border-primary/10 max-w-2xl">
                    <div class="flex flex-col sm:flex-row gap-3">
                        <input type="text" id="magicKeywords" class="flex-1 bg-dark-900/80 border border-gray-700 rounded-xl px-5 py-3 text-[12px] text-white focus:ring-1 focus:ring-primary transition-all placeholder-gray-600" placeholder="Keywords for Magic Expand...">
                        <button id="btnMagicGenerate" class="bg-primary hover:bg-secondary text-dark-900 text-[11px] font-bold px-8 py-3 rounded-xl transition-all flex items-center justify-center gap-2">
                            <i class="ti ti-sparkles"></i> Magic Expand
                        </button>
                    </div>
                </div>

                <!-- Master Formula -->
                <div class="space-y-6">
                    <div class="bg-dark-900/30 rounded-2xl border border-gray-700/20 p-4">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                            <div class="space-y-2">
                                <label class="text-[9px] font-bold text-gray-500 uppercase tracking-widest px-1">Social Format</label>
                                <select id="builderSocialFormat" class="social-format-select w-full bg-dark-900 border border-gray-700/50 rounded-xl px-3 py-3 text-[11px] text-white focus:ring-1 focus:ring-primary appearance-none cursor-pointer custom-scrollbar">
                                    <option value="" data-aspect="" data-context="">General Image</option>
                                    <option value="youtube_thumbnail" data-aspect="16:9" data-context="YouTube thumbnail cover, clickable high-retention composition, bold readable focal point, strong emotion, clear foreground subject, leave clean negative space for title placement but do not add text unless requested">YouTube Thumbnail 16:9</option>
                                    <option value="shorts_cover" data-aspect="9:16" data-context="vertical short-form video cover for YouTube Shorts, TikTok, and Instagram Reels, strong center subject, top-safe and bottom-safe composition, instant hook in the first glance">Shorts / TikTok / Reels 9:16</option>
                                    <option value="instagram_square" data-aspect="1:1" data-context="Instagram feed square post, balanced centered composition, scroll-stopping visual clarity, premium social media editorial finish">Instagram Square 1:1</option>
                                    <option value="instagram_portrait" data-aspect="4:5" data-context="Instagram portrait feed or carousel cover, vertical editorial crop, subject framed for mobile feed, high clarity at small size">Instagram Portrait 4:5</option>
                                    <option value="social_banner" data-aspect="191:100" data-context="social media link preview or cover banner, wide 1.91:1 crop, strong left-to-right composition, clean center focus, readable as a header image">Social Banner 1.91:1</option>
                                </select>
                            </div>
                            <div class="space-y-2">
                                <label class="text-[9px] font-bold text-gray-500 uppercase tracking-widest px-1">Category</label>
                                <select id="builderContentCategory" class="w-full bg-dark-900 border border-gray-700/50 rounded-xl px-3 py-3 text-[11px] text-white focus:ring-1 focus:ring-primary appearance-none cursor-pointer custom-scrollbar">
                                    <option value="">General Creative</option>
                                    <option value="product launch, advertising visual, clear product hero, premium commercial styling">Product Promo</option>
                                    <option value="gaming content cover, energetic action, dramatic character pose, high-impact thumbnail readability">Gaming</option>
                                    <option value="music artwork cover, emotional atmosphere, memorable visual identity, album-art quality">Music Cover</option>
                                    <option value="education and tutorial cover, clear concept visualization, trustworthy and clean information design">Education / Tutorial</option>
                                    <option value="lifestyle and travel social content, aspirational mood, authentic scene, polished creator aesthetic">Lifestyle / Travel</option>
                                    <option value="food and beverage social content, appetizing texture, fresh highlights, premium close-up styling">Food / Beverage</option>
                                </select>
                            </div>
                            <div class="space-y-2">
                                <label class="text-[9px] font-bold text-gray-500 uppercase tracking-widest px-1">Theme</label>
                                <select id="builderContentTheme" class="w-full bg-dark-900 border border-gray-700/50 rounded-xl px-3 py-3 text-[11px] text-white focus:ring-1 focus:ring-primary appearance-none cursor-pointer custom-scrollbar">
                                    <option value="">Auto Theme</option>
                                    <option value="viral cinematic, dramatic contrast, big visual hook, premium color grade">Viral Cinematic</option>
                                    <option value="clean minimal, elegant spacing, refined modern layout, premium simplicity">Clean Minimal</option>
                                    <option value="luxury premium, elegant materials, refined highlights, aspirational mood">Luxury Premium</option>
                                    <option value="dark dramatic, deep shadows, intense mood, powerful contrast">Dark Dramatic</option>
                                    <option value="bright colorful, playful energy, vibrant contrast, optimistic social pop">Bright Colorful</option>
                                    <option value="cozy natural, warm atmosphere, authentic textures, soft realistic light">Cozy Natural</option>
                                    <option value="tech futuristic, sleek surfaces, luminous accents, advanced digital atmosphere">Tech Futuristic</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <% ['Subject', 'Activity', 'Location'].forEach(field => { %>
                            <div class="space-y-2">
                                <label class="text-[9px] font-bold text-gray-500 uppercase tracking-widest px-1"><%= field %></label>
                                <div class="flex flex-col gap-2">
                                    <select onchange="updateField('<%= field.toLowerCase() %>', this.value)" class="w-full bg-dark-900 border border-gray-700/50 rounded-xl px-3 py-3 text-[11px] text-white focus:ring-1 focus:ring-primary appearance-none cursor-pointer custom-scrollbar">
                                        <option value="" class="bg-dark-800">Select <%= field %>...</option>
                                        <% if (field === 'Subject') { %>
                                            <optgroup label="Humans" class="bg-dark-800 text-gray-500 text-[9px]">
                                                <option value="A majestic cyber samurai" class="bg-dark-800 text-white">Cyber Samurai</option>
                                                <option value="A Victorian steampunk detective" class="bg-dark-800 text-white">Steampunk Detective</option>
                                                <option value="An ethereal celestial priestess" class="bg-dark-800 text-white">Celestial Priestess</option>
                                            </optgroup>
                                            <optgroup label="Animals & Insects" class="bg-dark-800 text-gray-500 text-[9px]">
                                                <option value="A majestic phoenix rising from embers" class="bg-dark-800 text-white">Phoenix</option>
                                                <option value="A cybernetic white wolf" class="bg-dark-800 text-white">Cyber Wolf</option>
                                                <option value="A glowing neon dragonfly" class="bg-dark-800 text-white">Neon Dragonfly</option>
                                            </optgroup>
                                            <optgroup label="Aliens & Abstract" class="bg-dark-800 text-gray-500 text-[9px]">
                                                <option value="A bioluminescent alien entity" class="bg-dark-800 text-white">Biolum Alien</option>
                                                <option value="Liquid gold vortex energy" class="bg-dark-800 text-white">Gold Vortex</option>
                                                <option value="A fusion of lion and dragon" class="bg-dark-800 text-white">Lion-Dragon Fusion</option>
                                            </optgroup>
                                        <% } else if (field === 'Activity') { %>
                                            <option value="standing in a heroic cinematic pose" class="bg-dark-800 text-white">Heroic Pose</option>
                                            <option value="engaged in an epic battle" class="bg-dark-800 text-white">Epic Battle</option>
                                            <option value="casting a powerful magic spell" class="bg-dark-800 text-white">Spellcasting</option>
                                            <option value="slowly dissolving into digital dust" class="bg-dark-800 text-white">Digital Dust</option>
                                        <% } else if (field === 'Location') { %>
                                            <option value="in a neon-drenched cyberpunk megalopolis" class="bg-dark-800 text-white">Cyber City</option>
                                            <option value="inside a bioluminescent underwater cave" class="bg-dark-800 text-white">Glow Ocean</option>
                                            <option value="atop a floating zen garden" class="bg-dark-800 text-white">Sky Garden</option>
                                            <option value="in a dark academia magic library" class="bg-dark-800 text-white">Magic Library</option>
                                        <% } %>
                                    </select>
                                    <input type="text" id="<%= field.toLowerCase() %>" class="w-full bg-dark-900/50 border border-gray-700/30 rounded-xl px-4 py-2.5 text-[11px] text-white focus:ring-1 focus:ring-primary" placeholder="Or type manually...">
                                </div>
                            </div>
                        <% }); %>
                    </div>

                    <!-- Aesthetics -->
                    <div class="pt-4">
                        <div class="h-px bg-gray-700/20 w-full flex items-center justify-center mb-6">
                            <span class="bg-dark-800 px-4 text-[9px] text-gray-600 uppercase tracking-[0.3em] font-bold">Aesthetics Configuration</span>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-3">
                            <% ['Art Style', 'Lighting', 'Mood', 'Colors', 'Camera', 'Technical'].forEach(field => { %>
                                <% const id = field.toLowerCase().replace(' ', ''); %>
                                <div class="bg-dark-900/30 p-4 rounded-xl border border-gray-700/20 space-y-2">
                                    <label class="text-[9px] font-bold text-gray-500 uppercase tracking-wider block"><%= field %></label>
                                    <select onchange="updateField('<%= id %>', this.value)" class="w-full bg-dark-700/50 border border-gray-600/30 rounded-lg px-2 py-2 text-[10px] text-white focus:ring-1 focus:ring-primary appearance-none custom-scrollbar">
                                        <option value="" class="bg-dark-800">Choose...</option>
                                        <% if(id === 'artstyle') { %>
                                            <optgroup label="Photorealism" class="bg-dark-800 text-gray-500 text-[9px]">
                                                <option value="Photorealistic real photo, natural skin texture, authentic details, lifelike proportions" class="bg-dark-800 text-white">Real Photo</option>
                                                <option value="Documentary photography, candid real-life moment, natural environment, unposed" class="bg-dark-800 text-white">Documentary Real</option>
                                                <option value="Editorial commercial photography, premium realistic product shot, clean professional finish" class="bg-dark-800 text-white">Editorial Real</option>
                                                <option value="Raw smartphone photography, real-world lighting, casual authentic snapshot" class="bg-dark-800 text-white">Phone Camera Real</option>
                                            </optgroup>
                                            <optgroup label="Cinematic & 3D" class="bg-dark-800 text-gray-500 text-[9px]">
                                            <option value="Unreal Engine 5 Render, 8k, hyper-realistic" class="bg-dark-800 text-white">UE5 Viral</option>
                                            <option value="Studio Ghibli style, hand-drawn, whimsical" class="bg-dark-800 text-white">Studio Ghibli</option>
                                            <option value="Disney Pixar 3D style, cute, expressive" class="bg-dark-800 text-white">Pixar Style</option>
                                            <option value="Retro 80s Synthwave, neon pink and purple" class="bg-dark-800 text-white">Synthwave</option>
                                            <option value="Dark Academia, oil painting, dramatic" class="bg-dark-800 text-white">Dark Academia</option>
                                            <option value="Cyberpunk 2077 aesthetic, gritty, high-tech" class="bg-dark-800 text-white">Cyberpunk</option>
                                            </optgroup>
                                        <% } else if(id === 'lighting') { %>
                                            <option value="Cinematic rim lighting, high contrast" class="bg-dark-800 text-white">Cinematic Rim</option>
                                            <option value="Volumetric fog, god rays, atmospheric" class="bg-dark-800 text-white">God Rays</option>
                                            <option value="Soft bokeh, golden hour sunlight" class="bg-dark-800 text-white">Golden Hour</option>
                                            <option value="Harsh neon flickering lights" class="bg-dark-800 text-white">Neon Flicker</option>
                                            <option value="Natural daylight, soft shadows, realistic exposure" class="bg-dark-800 text-white">Natural Daylight</option>
                                            <option value="Low-key studio lighting, deep shadows, dramatic highlights" class="bg-dark-800 text-white">Low Key Studio</option>
                                            <option value="High-key studio lighting, bright clean whites, soft even illumination" class="bg-dark-800 text-white">High Key Studio</option>
                                            <option value="Practical indoor lighting, warm lamps, believable room ambience" class="bg-dark-800 text-white">Indoor Practical</option>
                                        <% } else if(id === 'mood') { %>
                                            <option value="Calm, cozy, peaceful, relaxing atmosphere" class="bg-dark-800 text-white">Cozy Calm</option>
                                            <option value="Mysterious, cinematic, suspenseful, shadowy mood" class="bg-dark-800 text-white">Mysterious</option>
                                            <option value="Epic, powerful, heroic, awe-inspiring energy" class="bg-dark-800 text-white">Epic Heroic</option>
                                            <option value="Romantic, soft, intimate, dreamy feeling" class="bg-dark-800 text-white">Romantic</option>
                                            <option value="Dark, gritty, intense, serious atmosphere" class="bg-dark-800 text-white">Dark Gritty</option>
                                            <option value="Joyful, bright, playful, optimistic mood" class="bg-dark-800 text-white">Joyful</option>
                                            <option value="Lonely, melancholic, quiet, reflective tone" class="bg-dark-800 text-white">Melancholic</option>
                                            <option value="Luxury, elegant, premium, refined atmosphere" class="bg-dark-800 text-white">Luxury</option>
                                        <% } else if(id === 'colors') { %>
                                            <option value="Natural realistic colors, balanced contrast, true-to-life tones" class="bg-dark-800 text-white">Natural Real</option>
                                            <option value="Warm amber and soft brown palette, cozy highlights" class="bg-dark-800 text-white">Warm Amber</option>
                                            <option value="Cool blue and teal palette, clean modern contrast" class="bg-dark-800 text-white">Cool Teal</option>
                                            <option value="Pastel color palette, soft low saturation, airy look" class="bg-dark-800 text-white">Pastel Soft</option>
                                            <option value="Bold neon palette, electric magenta, cyan, violet accents" class="bg-dark-800 text-white">Neon Pop</option>
                                            <option value="Monochrome black and white, rich contrast, timeless look" class="bg-dark-800 text-white">Black White</option>
                                            <option value="Earthy green, terracotta, muted natural palette" class="bg-dark-800 text-white">Earth Tone</option>
                                            <option value="High contrast complementary colors, striking visual separation" class="bg-dark-800 text-white">High Contrast</option>
                                        <% } else if(id === 'camera') { %>
                                            <option value="Close-up portrait shot, shallow depth of field, eye-level angle" class="bg-dark-800 text-white">Close Portrait</option>
                                            <option value="Wide establishing shot, full environment visible, cinematic framing" class="bg-dark-800 text-white">Wide Shot</option>
                                            <option value="Low angle shot, powerful perspective, dramatic scale" class="bg-dark-800 text-white">Low Angle</option>
                                            <option value="Top-down overhead shot, clean composition, graphic layout" class="bg-dark-800 text-white">Top Down</option>
                                            <option value="Macro lens photography, extreme detail, creamy background blur" class="bg-dark-800 text-white">Macro Lens</option>
                                            <option value="35mm lens, natural perspective, realistic documentary framing" class="bg-dark-800 text-white">35mm Real</option>
                                            <option value="85mm portrait lens, compressed background, soft bokeh" class="bg-dark-800 text-white">85mm Portrait</option>
                                            <option value="Handheld camera feel, subtle motion, candid realistic framing" class="bg-dark-800 text-white">Handheld Real</option>
                                        <% } else if(id === 'technical') { %>
                                            <option value="Ultra detailed, sharp focus, clean edges, high dynamic range" class="bg-dark-800 text-white">Ultra Detail</option>
                                            <option value="4k resolution, realistic texture, balanced exposure, no artifacts" class="bg-dark-800 text-white">4K Clean</option>
                                            <option value="Depth of field, f/1.8 aperture, creamy bokeh, subject isolation" class="bg-dark-800 text-white">DOF Bokeh</option>
                                            <option value="Shot on full-frame DSLR, ISO 100, natural grain, professional color grading" class="bg-dark-800 text-white">DSLR Pro</option>
                                            <option value="Cinematic color grading, film grain, anamorphic lens flare, 16:9 composition" class="bg-dark-800 text-white">Cinematic Tech</option>
                                            <option value="Product photography setup, sharp reflections, clean background, studio quality" class="bg-dark-800 text-white">Product Setup</option>
                                            <option value="Long exposure effect, smooth motion trails, stable tripod composition" class="bg-dark-800 text-white">Long Exposure</option>
                                            <option value="Negative prompt: low quality, blurry, distorted anatomy, extra fingers, watermark, text artifacts" class="bg-dark-800 text-white">Clean Negative</option>
                                        <% } %>
                                    </select>
                                    <input type="text" id="<%= id %>" class="w-full bg-transparent border-b border-gray-700 text-[10px] text-white focus:border-primary outline-none py-1 transition-colors" placeholder="Type here...">
                                </div>
                            <% }); %>
                        </div>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-3 pt-4">
                        <button id="btnGeneratePrompt" class="flex-1 bg-primary hover:bg-secondary text-dark-900 text-[11px] font-bold py-4 rounded-xl transition-all shadow-lg shadow-primary/10">Build Master Prompt</button>
                        <button id="btnClear" class="bg-dark-700 hover:bg-dark-600 text-gray-400 text-[11px] px-8 py-4 rounded-xl transition-all">Clear All</button>
                    </div>

                    <div id="outputContainer" class="hidden animate-in slide-in-from-bottom-4 duration-300">
                        <div class="bg-dark-900 rounded-2xl border border-primary/20 p-5 space-y-3">
                            <div class="flex items-center justify-between">
                                <span class="text-[9px] font-bold text-primary uppercase tracking-widest">Constructed v3 Prompt</span>
                                <button onclick="copyToClipboard('resultPrompt')" class="text-[9px] text-white hover:text-primary transition-colors uppercase font-bold flex items-center gap-2">
                                    <i class="ti ti-copy"></i> Copy Prompt
                                </button>
                            </div>
                            <textarea id="resultPrompt" class="w-full bg-dark-800/50 border border-gray-700/50 rounded-xl p-4 text-[12px] text-gray-200 h-28 focus:ring-0 resize-none leading-relaxed" readonly></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 2: Generate Image -->
            <div id="studio-generate" class="studio-content hidden animate-in fade-in duration-300">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                    <div class="lg:col-span-8 space-y-6">
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                            <div class="space-y-2">
                                <label class="block text-[9px] font-bold text-gray-600 uppercase tracking-[0.2em] px-1">Social Format</label>
                                <select id="directSocialFormat" class="social-format-select w-full bg-dark-900 border border-gray-700/50 rounded-xl px-4 py-3 text-[11px] text-white focus:ring-1 focus:ring-primary appearance-none cursor-pointer custom-scrollbar">
                                    <option value="" data-aspect="" data-context="">General Image</option>
                                    <option value="youtube_thumbnail" data-aspect="16:9" data-context="YouTube thumbnail cover, clickable high-retention composition, bold readable focal point, strong emotion, clear foreground subject, leave clean negative space for title placement but do not add text unless requested">YouTube Thumbnail</option>
                                    <option value="shorts_cover" data-aspect="9:16" data-context="vertical short-form video cover for YouTube Shorts, TikTok, and Instagram Reels, strong center subject, top-safe and bottom-safe composition, instant hook in the first glance">Shorts / TikTok / Reels</option>
                                    <option value="instagram_square" data-aspect="1:1" data-context="Instagram feed square post, balanced centered composition, scroll-stopping visual clarity, premium social media editorial finish">Instagram Square</option>
                                    <option value="instagram_portrait" data-aspect="4:5" data-context="Instagram portrait feed or carousel cover, vertical editorial crop, subject framed for mobile feed, high clarity at small size">Instagram Portrait</option>
                                    <option value="social_banner" data-aspect="191:100" data-context="social media link preview or cover banner, wide 1.91:1 crop, strong left-to-right composition, clean center focus, readable as a header image">Social Banner</option>
                                </select>
                            </div>
                            <div class="space-y-2">
                                <label class="block text-[9px] font-bold text-gray-600 uppercase tracking-[0.2em] px-1">Category</label>
                                <select id="directContentCategory" class="w-full bg-dark-900 border border-gray-700/50 rounded-xl px-4 py-3 text-[11px] text-white focus:ring-1 focus:ring-primary appearance-none cursor-pointer custom-scrollbar">
                                    <option value="">General Creative</option>
                                    <option value="product launch, advertising visual, clear product hero, premium commercial styling">Product Promo</option>
                                    <option value="gaming content cover, energetic action, dramatic character pose, high-impact thumbnail readability">Gaming</option>
                                    <option value="music artwork cover, emotional atmosphere, memorable visual identity, album-art quality">Music Cover</option>
                                    <option value="education and tutorial cover, clear concept visualization, trustworthy and clean information design">Education / Tutorial</option>
                                    <option value="lifestyle and travel social content, aspirational mood, authentic scene, polished creator aesthetic">Lifestyle / Travel</option>
                                    <option value="food and beverage social content, appetizing texture, fresh highlights, premium close-up styling">Food / Beverage</option>
                                </select>
                            </div>
                            <div class="space-y-2">
                                <label class="block text-[9px] font-bold text-gray-600 uppercase tracking-[0.2em] px-1">Theme</label>
                                <select id="directContentTheme" class="w-full bg-dark-900 border border-gray-700/50 rounded-xl px-4 py-3 text-[11px] text-white focus:ring-1 focus:ring-primary appearance-none cursor-pointer custom-scrollbar">
                                    <option value="">Auto Theme</option>
                                    <option value="viral cinematic, dramatic contrast, big visual hook, premium color grade">Viral Cinematic</option>
                                    <option value="clean minimal, elegant spacing, refined modern layout, premium simplicity">Clean Minimal</option>
                                    <option value="luxury premium, elegant materials, refined highlights, aspirational mood">Luxury Premium</option>
                                    <option value="dark dramatic, deep shadows, intense mood, powerful contrast">Dark Dramatic</option>
                                    <option value="bright colorful, playful energy, vibrant contrast, optimistic social pop">Bright Colorful</option>
                                    <option value="cozy natural, warm atmosphere, authentic textures, soft realistic light">Cozy Natural</option>
                                    <option value="tech futuristic, sleek surfaces, luminous accents, advanced digital atmosphere">Tech Futuristic</option>
                                </select>
                            </div>
                        </div>

                        <div class="space-y-3">
                            <label class="block text-[9px] font-bold text-gray-600 uppercase tracking-[0.2em] px-1">Describe Your Vision</label>
                            <textarea id="directPrompt" class="w-full bg-dark-900 border border-gray-700/50 rounded-2xl p-6 text-[13px] text-white placeholder-gray-600 focus:ring-1 focus:ring-primary h-[180px] custom-scrollbar resize-none shadow-inner" placeholder="Visualize your masterpiece..."></textarea>
                        </div>
                        <div class="space-y-3">
                            <label class="block text-[9px] font-bold text-gray-600 uppercase tracking-[0.2em] px-1">Negative Prompt</label>
                            <input type="text" id="directNegative" class="w-full bg-dark-900 border border-gray-700/50 rounded-xl p-4 text-[12px] text-gray-400 focus:ring-1 focus:ring-primary shadow-inner" placeholder="E.g. low quality, distorted...">
                        </div>
                    </div>
                    
                    <div class="lg:col-span-4 space-y-6">
                        <div class="bg-dark-900/80 p-4 sm:p-6 rounded-2xl sm:rounded-3xl border border-gray-700/30 space-y-6 sm:space-y-8">
                            <div>
                                <label class="block text-[9px] font-bold text-gray-500 uppercase tracking-[0.2em] mb-4">Aspect Ratio</label>
                                <select id="directAspectRatio" class="w-full bg-dark-700 border border-gray-600 rounded-xl py-4 px-4 text-[11px] text-white appearance-none cursor-pointer hover:bg-dark-600 transition-colors">
                                    <option value="1:1">Square (1:1)</option>
                                    <option value="9:16">Portrait (9:16)</option>
                                    <option value="16:9">Landscape (16:9)</option>
                                    <option value="4:5">Portrait (4:5)</option>
                                    <option value="3:4">Portrait (3:4)</option>
                                    <option value="4:3">Landscape (4:3)</option>
                                    <option value="21:9">Wide (21:9)</option>
                                    <option value="191:100">Social Banner (1.91:1)</option>
                                    <option value="custom">Custom</option>
                                </select>
                                <div id="customAspectWrap" class="hidden grid grid-cols-[1fr_auto_1fr] gap-2 items-center mt-3">
                                    <input type="number" id="customAspectW" min="1" max="300" value="4" class="w-full bg-dark-700 border border-gray-600 rounded-xl py-3 px-4 text-[11px] text-white focus:ring-1 focus:ring-primary">
                                    <span class="text-gray-500 text-xs font-black">:</span>
                                    <input type="number" id="customAspectH" min="1" max="300" value="5" class="w-full bg-dark-700 border border-gray-600 rounded-xl py-3 px-4 text-[11px] text-white focus:ring-1 focus:ring-primary">
                                </div>
                            </div>
                            <div>
                                <label class="block text-[9px] font-bold text-gray-500 uppercase tracking-[0.2em] mb-4">Image Count</label>
                                <select id="directCount" class="w-full bg-dark-700 border border-gray-600 rounded-xl py-4 px-4 text-[11px] text-white appearance-none cursor-pointer hover:bg-dark-600 transition-colors">
                                    <option value="1">1 Image</option>
                                    <option value="2">2 Images</option>
                                    <option value="3">3 Images</option>
                                    <option value="4">4 Images</option>
                                    <option value="5">5 Images</option>
                                </select>
                            </div>
                            <button onclick="generateDirectImage()" id="btnDirectGenerate" class="w-full py-5 bg-primary hover:bg-secondary text-dark-900 font-black rounded-2xl transition-all flex items-center justify-center gap-3 shadow-xl shadow-primary/10 active:scale-[0.97] group">
                                <i class="ti ti-sparkles text-lg group-hover:rotate-12 transition-transform"></i>
                                <span class="text-xs uppercase tracking-widest">Generate Art</span>
                            </button>
                        </div>
                    </div>
                </div>

                <div id="resultsGallery" class="mt-12 hidden border-t border-gray-700/20 pt-10">
                    <div id="galleryGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                        <!-- Items prepend here -->
                    </div>
                </div>
            </div>

            <!-- Tab 3: History (Dedicated Tab) -->
            <div id="studio-history" class="studio-content hidden animate-in slide-in-from-bottom-4 duration-300">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-8">
                    <div class="flex items-center gap-3">
                        <div class="w-1 h-6 bg-primary rounded-full"></div>
                        <h3 class="text-[11px] font-black text-gray-400 uppercase tracking-[0.4em]">Prompt History</h3>
                    </div>
                    <p class="text-[9px] text-gray-600 italic font-bold">Total <span id="historyCount"><%= history.length %></span> items recorded</p>
                </div>
                
                <div id="historyGrid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                    <% if (history && history.length > 0) { %>
                        <% history.forEach(item => { %>
                            <div class="bg-dark-900/50 rounded-2xl border border-gray-700/30 p-5 hover:border-primary/40 transition-all group relative">
                                <% if (item.image_url) { %>
                                    <button type="button" data-image-url="<%= encodeURIComponent(item.image_url) %>" onclick="viewImage(decodeURIComponent(this.dataset.imageUrl))" class="w-full overflow-hidden rounded-xl bg-dark-800 border border-gray-700/30 mb-4 block">
                                        <img src="<%= item.image_url %>" alt="Generated image preview" class="w-full h-36 object-cover" loading="lazy">
                                    </button>
                                <% } %>
                                <p class="text-[11px] text-gray-300 line-clamp-3 leading-relaxed italic mb-5">"<%= item.prompt_text %>"</p>
                                <div class="flex items-center justify-between pt-4 border-t border-gray-700/20">
                                    <span class="text-[9px] text-gray-600 font-bold tracking-tighter"><%= new Date(item.created_at).toLocaleString() %></span>
                                    <div class="flex gap-2">
                                        <button data-prompt="<%= encodeURIComponent(item.prompt_text) %>" onclick="copyRawPrompt(this, decodeURIComponent(this.dataset.prompt))" class="w-9 h-9 flex items-center justify-center bg-dark-700 hover:bg-primary/20 text-gray-500 hover:text-primary rounded-xl transition-all" title="Copy Text">
                                            <i class="ti ti-copy text-sm"></i>
                                        </button>
                                        <button data-prompt="<%= encodeURIComponent(item.prompt_text) %>" onclick="reusePrompt(decodeURIComponent(this.dataset.prompt))" class="w-9 h-9 flex items-center justify-center bg-dark-700 hover:bg-primary/20 text-gray-500 hover:text-primary rounded-xl transition-all" title="Use as Prompt">
                                            <i class="ti ti-refresh text-sm"></i>
                                        </button>
                                        <button data-id="<%= item.id %>" onclick="deleteHistory(this.dataset.id)" class="w-9 h-9 flex items-center justify-center bg-dark-700 hover:bg-red-500/10 text-gray-500 hover:text-red-400 rounded-xl transition-all" title="Delete">
                                            <i class="ti ti-trash text-sm"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div id="historyEmptyState" class="col-span-full py-20 flex flex-col items-center justify-center opacity-30">
                            <i class="ti ti-history text-4xl mb-4"></i>
                            <span class="text-xs font-black uppercase tracking-widest">No History Available</span>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div id="imageModal" class="fixed inset-0 bg-black/98 z-[100] hidden items-center justify-center p-4 sm:p-8 backdrop-blur-xl" onclick="closeImageModal()">
    <div class="relative w-full h-full flex items-center justify-center" onclick="event.stopPropagation()">
        <div class="absolute top-3 right-3 z-10 flex items-center gap-2">
            <button type="button" id="modalDownloadBtn" class="modal-icon-btn" title="Download image" aria-label="Download image">
                <i class="ti ti-download"></i>
            </button>
            <button type="button" id="modalGalleryBtn" class="modal-icon-btn" title="Save to gallery" aria-label="Save to gallery">
                <i class="ti ti-photo-plus"></i>
            </button>
            <button type="button" class="modal-icon-btn" title="Close preview" aria-label="Close preview" onclick="closeImageModal()">
                <i class="ti ti-x"></i>
            </button>
        </div>
        <img id="modalImg" src="" class="max-w-[96vw] max-h-[92vh] object-contain rounded-2xl shadow-2xl border border-gray-800/50" alt="Full generated image preview">
    </div>
</div>

<script>
    (function() {
        window.switchStudioTab = function(tab) {
            document.querySelectorAll('.studio-tab').forEach(t => {
                t.classList.remove('active');
                t.classList.add('text-gray-500');
            });
            document.querySelectorAll('.studio-content').forEach(c => c.classList.add('hidden'));

            document.getElementById(`tab-${tab}`).classList.add('active');
            document.getElementById(`tab-${tab}`).classList.remove('text-gray-500');
            document.getElementById(`studio-${tab}`).classList.remove('hidden');
        };

        window.updateField = function(id, val) {
            if (val) {
                const el = document.getElementById(id);
                if (el) el.value = val;
            }
        };

        const defaultNegativePrompt = 'low quality, blurry, pixelated, distorted anatomy, bad proportions, extra fingers, missing fingers, warped hands, duplicated limbs, deformed face, crossed eyes, text artifacts, watermark, logo, signature, jpeg artifacts, noisy background, oversaturated colors, underexposed, flat lighting';
        const maxParallelImageJobs = 2;
        const modalImageState = {
            url: '',
            prompt: '',
            historyId: null,
            resolution: null
        };

        function gcdClient(a, b) {
            while (b) {
                const temp = b;
                b = a % b;
                a = temp;
            }
            return a;
        }

        function normalizeClientAspectRatio(value) {
            const match = String(value || '1:1').match(/^(\d{1,3})\s*[:/x]\s*(\d{1,3})$/i);
            if (!match) return '1:1';
            const width = parseInt(match[1], 10);
            const height = parseInt(match[2], 10);
            if (!width || !height) return '1:1';
            const ratio = width / height;
            if (ratio < 0.2 || ratio > 5) return '1:1';
            const divisor = gcdClient(width, height);
            return `${width / divisor}:${height / divisor}`;
        }

        function getSelectedAspectRatio() {
            const selected = document.getElementById('directAspectRatio').value;
            if (selected !== 'custom') return normalizeClientAspectRatio(selected);
            const width = document.getElementById('customAspectW').value || '1';
            const height = document.getElementById('customAspectH').value || '1';
            return normalizeClientAspectRatio(`${width}:${height}`);
        }

        function getGenerationSize(aspectRatio) {
            const [width, height] = normalizeClientAspectRatio(aspectRatio).split(':').map(Number);
            const ratio = width / height;
            if (Math.abs(ratio - 1) < 0.08) return '1024x1024';
            return ratio > 1 ? '1792x1024' : '1024x1792';
        }

        function splitPromptSections(text) {
            const clean = String(text || '').replace(/\r/g, '').trim();
            const negativeMatch = clean.match(/(?:^|\n)\s*NEGATIVE(?:\s+PROMPT)?\s*:\s*([\s\S]*)$/i);
            const promptText = negativeMatch ? clean.slice(0, negativeMatch.index).trim() : clean;
            return {
                prompt: promptText.replace(/^\s*MASTER\s+PROMPT\s*:\s*/i, '').trim(),
                negative: negativeMatch ? negativeMatch[1].trim() : ''
            };
        }

        function getSelectedOption(select) {
            return select && select.options ? select.options[select.selectedIndex] : null;
        }

        function getSocialPromptContext(scope) {
            const formatSelect = document.getElementById(`${scope}SocialFormat`);
            const categorySelect = document.getElementById(`${scope}ContentCategory`);
            const themeSelect = document.getElementById(`${scope}ContentTheme`);
            const formatOption = getSelectedOption(formatSelect);
            const category = categorySelect?.value || '';
            const theme = themeSelect?.value || '';
            const aspectRatio = normalizeClientAspectRatio(formatOption?.dataset.aspect || '');
            const formatContext = formatOption?.dataset.context || '';
            const formatLabel = formatOption?.textContent?.trim() || '';
            const promptParts = [];

            if (formatContext) {
                promptParts.push(`Social media target: ${formatLabel}. ${formatContext}. Compose specifically for ${aspectRatio} aspect ratio.`);
            }
            if (category) {
                promptParts.push(`Content category: ${category}.`);
            }
            if (theme) {
                promptParts.push(`Theme direction: ${theme}.`);
            }

            return {
                aspectRatio: formatOption?.dataset.aspect ? aspectRatio : '',
                promptContext: promptParts.join(' ')
            };
        }

        function buildPromptWithSocialContext(prompt, socialContext) {
            if (!socialContext?.promptContext) return prompt;
            return `${prompt}\n\nSOCIAL MEDIA CREATIVE DIRECTION:\n${socialContext.promptContext}\nMake the final image instantly readable on mobile, with a strong focal point, clear crop-safe composition, and no unwanted text, watermark, logo, or UI elements.`;
        }

        function setSelectValue(selectId, value) {
            const select = document.getElementById(selectId);
            if (!select || !value) return;
            const option = Array.from(select.options).find(item => item.value === value);
            if (option) select.value = value;
        }

        function syncSocialFormatAspect(scope) {
            const social = getSocialPromptContext(scope);
            if (!social.aspectRatio) return;

            if (scope === 'direct') {
                setSelectValue('directAspectRatio', social.aspectRatio);
                document.getElementById('customAspectWrap').classList.add('hidden');
            }
        }

        function copyBuilderSocialToDirect() {
            ['SocialFormat', 'ContentCategory', 'ContentTheme'].forEach(suffix => {
                const source = document.getElementById(`builder${suffix}`);
                const target = document.getElementById(`direct${suffix}`);
                if (source && target) {
                    target.value = source.value;
                }
            });
            syncSocialFormatAspect('direct');
        }

        function buildCreativeMasterPrompt(fields) {
            const subject = fields.subject || 'A visually striking main subject with a memorable silhouette and expressive details';
            const activity = fields.activity || 'captured at the most cinematic moment of the scene';
            const location = fields.location || 'inside a richly layered environment with foreground, midground, and background depth';
            const style = fields.style || 'premium cinematic concept art with refined art direction';
            const lighting = fields.light || 'dramatic motivated lighting with soft highlights, realistic shadows, and atmospheric depth';
            const mood = fields.mood || 'immersive, emotionally engaging, mysterious, and awe-inspiring';
            const colors = fields.color || 'balanced color harmony with strong contrast, subtle accent colors, and polished grading';
            const camera = fields.cam || 'carefully composed camera angle, strong focal point, depth of field, and dynamic framing';

            let technical = fields.tech || 'ultra detailed, sharp focus, clean edges, high dynamic range, professional finish';
            let extraNegative = '';
            const negativeFromTech = technical.match(/negative prompt\s*:\s*([\s\S]*)/i);
            if (negativeFromTech) {
                extraNegative = negativeFromTech[1].trim();
                technical = 'clean professional rendering, artifact-free finish, polished image quality';
            }

            const socialDirection = fields.socialContext?.promptContext
                ? `Social media creative direction: ${fields.socialContext.promptContext} Design the image to stay readable as a thumbnail or cover on mobile screens, with crop-safe composition and a clear visual hierarchy.`
                : '';

            const master = [
                `MASTER PROMPT:\n${subject} ${activity} ${location}.`,
                `Develop the scene with a clear visual story: a strong focal subject, readable silhouette, purposeful gesture, layered environment details, and small believable textures that reward close inspection.`,
                socialDirection,
                `${style}, ${lighting}, ${mood}.`,
                `Use ${colors}; ${camera}.`,
                `Add cinematic depth, realistic material detail, atmospheric perspective, refined composition, premium editorial polish, and a distinct creative hook so the image feels original rather than generic.`,
                `${technical}.`
            ].filter(Boolean).join(' ');

            const negative = [defaultNegativePrompt, extraNegative].filter(Boolean).join(', ');
            return `${master}\n\nNEGATIVE:\n${negative}`;
        }

        function setDirectPromptFromText(text) {
            const parsed = splitPromptSections(text);
            const promptInput = document.getElementById('directPrompt');
            const negativeInput = document.getElementById('directNegative');
            if (promptInput) promptInput.value = parsed.prompt;
            if (negativeInput && parsed.negative) negativeInput.value = parsed.negative;
        }

        function compactToastMessage(message, maxLength = 190) {
            const clean = String(message || 'Unknown error').replace(/\s+/g, ' ').trim();
            return clean.length > maxLength ? `${clean.slice(0, maxLength - 1)}...` : clean;
        }

        const aspectSelect = document.getElementById('directAspectRatio');
        const customAspectWrap = document.getElementById('customAspectWrap');
        aspectSelect.addEventListener('change', () => {
            customAspectWrap.classList.toggle('hidden', aspectSelect.value !== 'custom');
        });
        document.getElementById('directSocialFormat').addEventListener('change', () => syncSocialFormatAspect('direct'));

        document.getElementById('magicKeywords').addEventListener('keydown', (event) => {
            if (event.key === 'Enter') {
                event.preventDefault();
                document.getElementById('btnMagicGenerate').click();
            }
        });

        document.getElementById('btnMagicGenerate').addEventListener('click', async () => {
            const keywords = document.getElementById('magicKeywords').value.trim();
            const btn = document.getElementById('btnMagicGenerate');
            if (keywords.length < 2) return showToast('Masukkan minimal 1 keyword.', 'warning');
            const socialContext = getSocialPromptContext('builder');
            const magicInput = buildPromptWithSocialContext(keywords, socialContext);

            btn.disabled = true;
            btn.innerHTML = `<i class="ti ti-loader animate-spin"></i> Expanding...`;

            try {
                const response = await fetch('/api/ai/magic-prompt', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ keywords: magicInput })
                });
                const data = await response.json();

                if (!data.success) {
                    showToast(data.error || 'Magic Expand gagal.', 'error');
                    return;
                }

                const fullPrompt = data.prompt || '';
                document.getElementById('resultPrompt').value = fullPrompt;
                window.currentPrompt = fullPrompt;
                document.getElementById('outputContainer').classList.remove('hidden');
                copyBuilderSocialToDirect();
                setDirectPromptFromText(fullPrompt);
                await savePromptHistory(fullPrompt);
                showToast('Magic prompt ready!', 'success');
            } catch (error) {
                showToast('Magic Expand error.', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = `<i class="ti ti-sparkles"></i> Magic Expand`;
            }
        });

        // Logic Builder
        document.getElementById('btnGeneratePrompt').addEventListener('click', () => {
            const subject = document.getElementById('subject').value.trim();
            const activity = document.getElementById('activity').value.trim();
            const location = document.getElementById('location').value.trim();
            const style = document.getElementById('artstyle').value.trim();
            const light = document.getElementById('lighting').value.trim();
            const mood = document.getElementById('mood').value.trim();
            const color = document.getElementById('colors').value.trim();
            const cam = document.getElementById('camera').value.trim();
            const tech = document.getElementById('technical').value.trim();
            const socialContext = getSocialPromptContext('builder');

            const fullPrompt = buildCreativeMasterPrompt({ subject, activity, location, style, light, mood, color, cam, tech, socialContext });

            document.getElementById('resultPrompt').value = fullPrompt;
            window.currentPrompt = fullPrompt;
            document.getElementById('outputContainer').classList.remove('hidden');
            copyBuilderSocialToDirect();
            setDirectPromptFromText(fullPrompt);
            savePromptHistory(fullPrompt);
        });

        document.getElementById('btnClear').addEventListener('click', () => {
            ['magicKeywords', 'subject', 'activity', 'location', 'artstyle', 'lighting', 'mood', 'colors', 'camera', 'technical', 'resultPrompt'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.value = '';
            });
            document.querySelectorAll('#studio-builder select').forEach(select => {
                select.selectedIndex = 0;
            });
            document.getElementById('outputContainer').classList.add('hidden');
        });

        window.generateDirectImage = async function() {
            const directText = document.getElementById('directPrompt').value.trim();
            const parsedDirect = splitPromptSections(directText);
            const prompt = parsedDirect.prompt;
            const negative = document.getElementById('directNegative').value.trim() || parsedDirect.negative;
            const socialContext = getSocialPromptContext('direct');
            const finalPrompt = buildPromptWithSocialContext(prompt, socialContext);
            const aspectRatio = socialContext.aspectRatio || getSelectedAspectRatio();
            const size = getGenerationSize(aspectRatio);
            const count = Math.min(Math.max(parseInt(document.getElementById('directCount').value, 10) || 1, 1), 5);
            const btn = document.getElementById('btnDirectGenerate');

            if (!prompt) return showToast('Enter prompt.', 'warning');

            btn.disabled = true;
            btn.innerHTML = `<i class="ti ti-loader animate-spin"></i> Queue 0/${count}`;

            const historyPrompt = negative ? `${finalPrompt}\n\nNEGATIVE:\n${negative}` : finalPrompt;
            let historyPromise = null;
            let completed = 0;
            let successCount = 0;
            let failedCount = 0;
            const placeholders = [];

            for (let i = 0; i < count; i++) {
                placeholders.push(createQueuedResultCard(prompt, {
                    aspectRatio,
                    index: i + 1,
                    count
                }));
            }

            const grid = ensureResultsGrid();
            const referenceNode = grid.firstChild;
            placeholders.forEach(card => grid.insertBefore(card, referenceNode));

            const ensureHistorySaved = (imageUrl) => {
                if (!historyPromise) historyPromise = savePromptHistory(historyPrompt, imageUrl);
                return historyPromise;
            };

            const jobs = placeholders.map((card, index) => async () => {
                setResultCardStatus(card, 'generating', `Generating ${index + 1}/${count}`);

                try {
                    const result = await requestSingleImage(finalPrompt, negative, size, aspectRatio);
                    const image = result.image;
                    const historyId = await ensureHistorySaved(image.imageUrl);

                    completeResultCard(card, image.imageUrl, prompt, {
                        aspectRatio: image.aspectRatio || aspectRatio,
                        resolution: image.resolution,
                        historyId
                    });
                    successCount += 1;

                    if (result.warnings.length) {
                        showToast(`Image ${index + 1} generated with warning.`, 'warning');
                    }
                } catch (error) {
                    failedCount += 1;
                    const reason = error.message || 'Generate failed.';
                    failResultCard(card, reason);
                    showToast(`Image ${index + 1} failed: ${compactToastMessage(reason)}`, 'error');
                } finally {
                    completed += 1;
                    btn.innerHTML = `<i class="ti ti-loader animate-spin"></i> Queue ${completed}/${count}`;
                }
            });

            try {
                await runImageQueue(jobs, Math.min(maxParallelImageJobs, count));

                if (successCount > 0 && failedCount === 0) {
                    showToast(`Generated ${successCount} image${successCount > 1 ? 's' : ''}.`, 'success');
                } else if (successCount > 0) {
                    showToast(`${successCount} generated, ${failedCount} failed.`, 'warning');
                } else {
                    showToast('All image jobs failed. Check the error on each card.', 'error');
                }
            } catch (error) {
                showToast(error.message || 'Queue failed.', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = `<i class="ti ti-sparkles"></i> Generate Art`;
            }
        };

        async function requestSingleImage(prompt, negative, size, aspectRatio) {
            const response = await fetch('/api/ai/generate-image', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ prompt, negativePrompt: negative, size, aspectRatio, count: 1 })
            });

            const data = await response.json().catch(() => ({}));
            if (!response.ok || !data.success) {
                throw new Error(data.error || `Generate failed with HTTP ${response.status}`);
            }

            const image = Array.isArray(data.images) && data.images.length
                ? data.images[0]
                : { imageUrl: data.imageUrl, aspectRatio: data.aspectRatio || aspectRatio, resolution: null };

            if (!image || !image.imageUrl) {
                throw new Error('Provider returned no image preview.');
            }

            return {
                image,
                warnings: Array.isArray(data.warnings) ? data.warnings : []
            };
        }

        async function runImageQueue(jobs, concurrency) {
            const queue = jobs.slice();
            const workers = Array.from({ length: concurrency }, async () => {
                while (queue.length) {
                    const job = queue.shift();
                    await job();
                }
            });
            await Promise.all(workers);
        }

        function ensureResultsGrid() {
            const gallery = document.getElementById('resultsGallery');
            const grid = document.getElementById('galleryGrid');
            gallery.classList.remove('hidden');
            return grid;
        }

        function createQueuedResultCard(prompt, meta = {}) {
            const item = document.createElement('div');
            item.className = 'gallery-item group animate-in zoom-in duration-500';
            item.style.setProperty('--result-aspect-ratio', (meta.aspectRatio || '1:1').replace(':', ' / '));
            item.dataset.prompt = prompt;
            item.dataset.resolution = meta.resolution || '';
            item.innerHTML = `
                <div class="result-preview-frame relative bg-dark-900 overflow-hidden">
                    <div class="result-status absolute inset-0 flex flex-col items-center justify-center gap-3 text-gray-500 text-[10px] font-bold uppercase tracking-widest p-4 text-center">
                        <i class="result-status-icon ti ti-clock text-2xl"></i>
                        <span class="result-status-text">Queued ${meta.index || 1}/${meta.count || 1}</span>
                        <span class="result-error hidden text-red-300 text-[10px] normal-case tracking-normal leading-relaxed max-w-[85%]"></span>
                    </div>
                    <img class="w-full h-full object-contain cursor-pointer transition-all duration-700 group-hover:scale-[1.03] opacity-0" alt="Generated image preview" loading="lazy">
                </div>
                <div class="absolute top-3 right-3 z-10 flex justify-end gap-2 result-actions">
                    <button type="button" class="preview-result result-action-btn" title="Full preview" aria-label="Full preview" disabled><i class="ti ti-arrows-maximize"></i></button>
                    <button type="button" class="download-result result-action-btn" title="Download image" aria-label="Download image" disabled><i class="ti ti-download"></i></button>
                    <button type="button" class="gallery-save-result result-action-btn" title="Save to gallery" aria-label="Save to gallery" disabled><i class="ti ti-photo-plus"></i></button>
                </div>
                <div class="gallery-overlay absolute inset-x-0 bottom-0 opacity-0 group-hover:opacity-100 transition-all p-5 pt-12">
                    <p class="text-[10px] text-gray-200 line-clamp-2 font-bold italic"></p>
                </div>
            `;
            item.querySelector('p').textContent = `"${prompt}"`;
            return item;
        }

        function setResultCardStatus(card, status, message) {
            const icon = card.querySelector('.result-status-icon');
            const text = card.querySelector('.result-status-text');
            const error = card.querySelector('.result-error');

            if (status === 'generating') {
                icon.className = 'result-status-icon ti ti-loader animate-spin text-primary text-2xl';
                text.textContent = message || 'Generating';
                error.classList.add('hidden');
            } else if (status === 'preview') {
                icon.className = 'result-status-icon ti ti-photo-check text-primary text-2xl';
                text.textContent = message || 'Loading preview';
                error.classList.add('hidden');
            }
        }

        function completeResultCard(card, url, prompt, meta = {}) {
            const image = card.querySelector('img');
            const status = card.querySelector('.result-status');
            const previewBtn = card.querySelector('.preview-result');
            const downloadBtn = card.querySelector('.download-result');
            const galleryBtn = card.querySelector('.gallery-save-result');

            card.dataset.imageUrl = url;
            card.dataset.prompt = prompt;
            card.dataset.historyId = meta.historyId || '';
            card.dataset.resolution = meta.resolution || '';
            card.dataset.aspectRatio = meta.aspectRatio || '1:1';
            setResultCardStatus(card, 'preview', 'Loading preview');

            image.onload = () => {
                image.classList.remove('opacity-0');
                status.classList.add('hidden');
            };
            image.onerror = () => failResultCard(card, 'Preview image failed to load.');
            image.src = url;
            image.addEventListener('click', () => viewImage(url, prompt, meta));

            [
                [previewBtn, () => viewImage(url, prompt, meta)],
                [downloadBtn, () => downloadDirect(url, prompt)],
                [galleryBtn, () => saveToGalleryDirect(url, prompt, meta.historyId, meta.resolution)]
            ].forEach(([button, handler]) => {
                button.disabled = false;
                button.addEventListener('click', handler);
            });
        }

        function failResultCard(card, message) {
            const status = card.querySelector('.result-status');
            const icon = card.querySelector('.result-status-icon');
            const text = card.querySelector('.result-status-text');
            const error = card.querySelector('.result-error');

            card.classList.add('border-red-500/40');
            status.classList.remove('hidden');
            icon.className = 'result-status-icon ti ti-alert-triangle text-red-400 text-2xl';
            text.textContent = 'Failed';
            error.textContent = message;
            error.classList.remove('hidden');
        }

        function addResultToGallery(url, prompt, meta = {}) {
            const grid = ensureResultsGrid();
            const item = createQueuedResultCard(prompt, meta);
            completeResultCard(item, url, prompt, meta);
            grid.prepend(item);
        }

        window.downloadDirect = async function(url, promptText = 'ai-generated-image') {
            try {
                const response = await fetch('/api/ai/download-image', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ imageUrl: url, filename: promptText })
                });
                if (!response.ok) {
                    const errorData = await response.json().catch(() => ({}));
                    throw new Error(errorData.error || 'Download failed');
                }
                const blob = await response.blob();
                const blobUrl = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = blobUrl;
                link.download = 'ai-generated-image.png';
                document.body.appendChild(link);
                link.click();
                link.remove();
                URL.revokeObjectURL(blobUrl);
                showToast('Download started.', 'success');
            } catch (error) {
                showToast(error.message || 'Download failed.', 'error');
            }
        };

        window.saveToGalleryDirect = async function(url, promptText = '', historyId = null, resolution = null) {
            try {
                const response = await fetch('/api/ai/save-to-gallery', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ imageUrl: url, prompt: promptText, historyId, resolution })
                });
                const data = await response.json();
                if (!data.success) {
                    showToast(data.error || 'Failed to save image.', 'error');
                    return;
                }
                showToast('Saved to Gallery.', 'success');
            } catch (error) {
                showToast('Failed to save image.', 'error');
            }
        };

        async function savePromptHistory(prompt, imageUrl = null) {
            try {
                const response = await fetch('/api/ai/save-history', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prompt, imageUrl })
                });
                const data = await response.json().catch(() => ({}));
                if (data.id) prependHistoryCard(data.id, prompt, imageUrl);
                return data.id || null;
            } catch (e) {}
            return null;
        }

        function prependHistoryCard(id, prompt, imageUrl = null) {
            const grid = document.getElementById('historyGrid');
            if (!grid) return;

            const empty = document.getElementById('historyEmptyState');
            if (empty) empty.remove();

            const card = document.createElement('div');
            card.className = 'bg-dark-900/50 rounded-2xl border border-gray-700/30 p-5 hover:border-primary/40 transition-all group relative';

            if (imageUrl) {
                const previewButton = document.createElement('button');
                previewButton.type = 'button';
                previewButton.className = 'w-full overflow-hidden rounded-xl bg-dark-800 border border-gray-700/30 mb-4 block';
                const previewImg = document.createElement('img');
                previewImg.src = imageUrl;
                previewImg.alt = 'Generated image preview';
                previewImg.loading = 'lazy';
                previewImg.className = 'w-full h-36 object-cover';
                previewButton.appendChild(previewImg);
                previewButton.addEventListener('click', () => viewImage(imageUrl));
                card.appendChild(previewButton);
            }

            const text = document.createElement('p');
            text.className = 'text-[11px] text-gray-300 line-clamp-3 leading-relaxed italic mb-5';
            text.textContent = `"${prompt}"`;
            card.appendChild(text);

            const footer = document.createElement('div');
            footer.className = 'flex items-center justify-between pt-4 border-t border-gray-700/20';
            footer.innerHTML = `
                <span class="text-[9px] text-gray-600 font-bold tracking-tighter">${new Date().toLocaleString()}</span>
                <div class="flex gap-2">
                    <button type="button" class="history-copy w-9 h-9 flex items-center justify-center bg-dark-700 hover:bg-primary/20 text-gray-500 hover:text-primary rounded-xl transition-all" title="Copy Text"><i class="ti ti-copy text-sm"></i></button>
                    <button type="button" class="history-reuse w-9 h-9 flex items-center justify-center bg-dark-700 hover:bg-primary/20 text-gray-500 hover:text-primary rounded-xl transition-all" title="Use as Prompt"><i class="ti ti-refresh text-sm"></i></button>
                    <button type="button" class="history-delete w-9 h-9 flex items-center justify-center bg-dark-700 hover:bg-red-500/10 text-gray-500 hover:text-red-400 rounded-xl transition-all" title="Delete"><i class="ti ti-trash text-sm"></i></button>
                </div>
            `;
            card.appendChild(footer);
            card.querySelector('.history-copy').addEventListener('click', function() { copyRawPrompt(this, prompt); });
            card.querySelector('.history-reuse').addEventListener('click', () => reusePrompt(prompt));
            card.querySelector('.history-delete').addEventListener('click', () => deleteHistory(id));

            grid.prepend(card);
            const count = document.getElementById('historyCount');
            if (count) count.textContent = String((parseInt(count.textContent, 10) || 0) + 1);
        }

        window.copyRawPrompt = function(btn, text) {
            const temp = document.createElement('textarea');
            temp.value = text;
            document.body.appendChild(temp);
            temp.select();
            document.execCommand('copy');
            document.body.removeChild(temp);
            showToast('Prompt copied!', 'success');
        };

        window.reusePrompt = function(text) {
            setDirectPromptFromText(text);
            switchStudioTab('generate');
            showToast('Prompt loaded!', 'info');
        };

        window.deleteHistory = async function(id) {
            if (!confirm('Delete record?')) return;
            try {
                const response = await fetch(`/api/ai/prompt-history/${id}`, { method: 'DELETE' });
                if ((await response.json()).success) location.reload();
            } catch (e) {}
        };

        window.closeImageModal = function() {
            const modal = document.getElementById('imageModal');
            const img = document.getElementById('modalImg');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            img.src = '';
        };

        window.viewImage = function(url, prompt = '', meta = {}) {
            const modal = document.getElementById('imageModal');
            const img = document.getElementById('modalImg');
            const downloadBtn = document.getElementById('modalDownloadBtn');
            const galleryBtn = document.getElementById('modalGalleryBtn');

            modalImageState.url = url;
            modalImageState.prompt = prompt || 'ai-generated-image';
            modalImageState.historyId = meta.historyId || null;
            modalImageState.resolution = meta.resolution || null;

            img.src = url;
            downloadBtn.onclick = () => downloadDirect(modalImageState.url, modalImageState.prompt);
            galleryBtn.onclick = () => saveToGalleryDirect(
                modalImageState.url,
                modalImageState.prompt,
                modalImageState.historyId,
                modalImageState.resolution
            );

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        };

        window.copyToClipboard = function(id) {
            const el = document.getElementById(id);
            el.select();
            document.execCommand('copy');
            showToast('Copied!', 'success');
        };

        // Toast Notification System
        window.showToast = function(message, type) {
            // Remove existing toast if any
            const existing = document.getElementById('studioToast');
            if (existing) existing.remove();

            const colors = {
                success: 'bg-green-500/20 border-green-500/50 text-green-400',
                error: 'bg-red-500/20 border-red-500/50 text-red-400',
                warning: 'bg-yellow-500/20 border-yellow-500/50 text-yellow-400',
                info: 'bg-blue-500/20 border-blue-500/50 text-blue-400'
            };
            const icons = {
                success: 'ti-check',
                error: 'ti-x',
                warning: 'ti-alert-triangle',
                info: 'ti-info-circle'
            };

            const toast = document.createElement('div');
            toast.id = 'studioToast';
            toast.className = `fixed top-6 right-6 z-[200] px-6 py-4 rounded-2xl border backdrop-blur-xl shadow-2xl flex items-center gap-3 transition-all animate-in slide-in-from-top-4 duration-300 ${colors[type] || colors.info}`;
            toast.innerHTML = `<i class="ti ${icons[type] || icons.info} text-lg"></i><span class="text-[12px] font-bold">${message}</span>`;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(-20px)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        };
    })();
</script>

